print("Hi, Welcome to Pisay's Grading System!")

# Compute current (tentative) grade
def compute_current_grade(fa, sa):
    return (fa * 0.30) + (sa * 0.70)

# Compute final grade (Q2–Q4)
def compute_final_grade(previous, current):
    return (previous + (current * 2)) / 3

# Grade equivalent + remarks
def get_result_and_equivalent(grade):
    if grade >= 96:
        return 1.00, "EXCELLENT"
    elif grade >= 90:
        return 1.25, "VERY GOOD"
    elif grade >= 84:
        return 1.50, "VERY GOOD"
    elif grade >= 78:
        return 1.75, "GOOD"
    elif grade >= 72:
        return 2.00, "GOOD"
    else:
        return 3.00, "NEEDS IMPROVEMENT"

# Ask for grade (Percentage) 
fa = float(input("Formative Assessment (FA): "))
sa = float(input("Summative Assessment (SA): "))

current = compute_current_grade(fa, sa)

# Ask for previous grade (optional)
prev_input = input("Previous quarter grade (press Enter if none): ")

if prev_input == "":
    final = current  # Q1 case
else:
    previous = float(prev_input)
    final = compute_final_grade(previous, current)

# Get equivalent + remarks
equivalent, remarks = get_result_and_equivalent(final)

# Output
print("\n--- RESULT ---")
print(f"Current Grade: {current:.2f}")
print(f"Final Grade: {final:.2f}")
print(f"Equivalent: {equivalent:.2f}")
print(f"Remarks: {remarks}")
